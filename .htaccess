Options -MultiViews
RewriteEngine On
RewriteBase /

# Ne pas réécrire si c'est un fichier réel ou un répertoire
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# N'appliquer la réécriture que si ce n'est pas un fichier statique
RewriteCond %{REQUEST_URI} !\.(?:js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|map|webp)$ [NC]
RewriteRule ^ /index.html [L]

# Configuration MIME pour éviter les erreurs
<IfModule mod_mime.c>
    AddType application/javascript js mjs
    AddType application/json json
    AddType image/svg+xml svg svgz
</IfModule>
